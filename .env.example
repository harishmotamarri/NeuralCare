# NeuralCare Environment Variables Configuration Example

# Hugging Face Read Token for downloading model weights (required for download_models.py)
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=your_huggingface_read_token_here

# Flask environment configuration
# 'development' enables debug mode, any other value disables it
FLASK_ENV=development

# Port to bind the Flask server to (defaults to 10000 if not specified)
PORT=10000
